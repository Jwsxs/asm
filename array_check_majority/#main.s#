
	.DATA
GMSG:	.ASCII "GREATER\n"
GMSG_LEN = . - GMSG

LMSG:	.ASCII "LESS\n"
LMSG_LEN = . - LMSG

	.TEXT
	.GLOBL _start

_start:
	PUSH %RBP
	MOVQ %RSP, %RBP

	SUB $0X28, %RSP # 40 BYTES | INT (4 BYTES) * 10 = 40

	MOVL $18, 0(%RSP)
	MOVL $17, 4(%RSP)
	MOVL $29, 8(%RSP) 
	MOVL $13, 12(%RSP)
	MOVL $15, 16(%RSP)
	MOVL $42, 20(%RSP) 
	MOVL $20, 24(%RSP)
	MOVL $96, 28(%RSP)
	MOVL $02, 32(%RSP) 
	MOVL $51, 36(%RSP)
	
	XOR %RDI, %RDI
	XOR %R8, %R8
	
READ_ARRAY:
	MOV %RDI, %R8
	CMPL $18, (%RSP, %RDI, 4) # 18
	JGE GREATER
	JMP LESS
	
GREATER:
	MOV $1, %RAX
	MOV $1, %RDI
	MOV $GMSG, %RSI
	MOV $GMSG_LEN, %RDX
	SYSCALL
	JMP .L1

LESS:
	MOV $1, %RAX
	MOV $1, %RDI
	MOV $LMSG, %RSI
	MOV $LMSG_LEN, %RDX
	SYSCALL
	
.L1:
	MOV %R8, %RDI
	INC %RDI
	CMP $0XA, %RDI
	JL READ_ARRAY
	
DONE:
	ADD $0X28, %RSP
	MOV $0X3C, %RAX
	XOR %RDI, %RDI
	SYSCALL
